# AgentGuard AI Review Configuration
# Copy to .env and fill in your values
# NEVER commit .env to version control

# Provider: anthropic | openai | anysphere | openai-compatible
AGENTGUARD_AI_PROVIDER=anthropic

# API key for the selected provider
AGENTGUARD_AI_API_KEY=your-api-key-here

# Base URL (only for openai-compatible providers)
# AGENTGUARD_AI_BASE_URL=https://your-api-endpoint/v1

# Model override (optional — provider default used if not set)
# AGENTGUARD_AI_MODEL=claude-haiku-4-5-20251001

# Model override for mission/hard_limits concretization
# Default: claude-sonnet-4-6 (Anthropic) / gpt-4o (OpenAI)
# For maximum concretization quality (2x cost):
# AGENTGUARD_MISSION_MODEL=claude-fable-5
#
# Claude Fable 5 (released June 9, 2026):
# - Mythos-class model, tier above Opus
# - API string: claude-fable-5
# - $10/$50 per million input/output tokens
# - Best for complex, long-running governance definitions
# - Free on Pro/Max/Team plans until June 22, 2026

# AgentGuard Governance Configuration Example
# Copy this file to governance.yaml and fill in the required fields.
# Generated by: agentguard init --guided (or edit manually)

owner: "Jane Smith"

scope:
  # authorized: what the agent MAY do — each item has action + reason
  authorized:
    - action: "Read and write Python files in ./src and ./tests"
      reason: "Core task — agent must modify source and test files"
      added: "2026-06-07"
    - action: "Run pytest suite to validate changes"
      reason: "Agent must verify correctness before proposing changes"
      added: "2026-06-07"

  # prohibited: what the agent MUST NOT do — severity: HARD_LIMIT | CRITICAL | WARNING
  prohibited:
    - action: "No database schema changes or writes to production tables"
      reason: "Production data changes require human review — no exceptions"
      severity: "HARD_LIMIT"
      added: "2026-06-07"
    - action: "No git push to main or master branch"
      reason: "All changes must go through pull request review process"
      severity: "HARD_LIMIT"
      added: "2026-06-07"
    - action: "No external API calls outside documented integrations"
      reason: "Security boundary — unknown API calls may exfiltrate data"
      severity: "CRITICAL"
      added: "2026-06-07"

  # requires_confirmation: allowed, but human must approve first
  requires_confirmation:
    - action: "Any file deletion outside ./tmp directory"
      reason: "File deletion is irreversible — requires explicit human sign-off"
      added: "2026-06-07"
    - action: "Any change to configuration files (.env, settings.*)"
      reason: "Config changes affect all environments — high-risk"
      added: "2026-06-07"

escalation:
  contact: "jane@example.com"   # Email, Slack handle, or full name
  method: "log"                  # log | terminal | file
  trigger: "2+ critical failures or loop detected"

killswitch: "Ctrl+C"             # How to stop: "Ctrl+C", "kill PID", "endpoint URL"

# governance_history: automatically maintained — do not edit manually
governance_history:
  - date: "2026-06-07"
    action: "Initial governance created"
    tool: "agentguard init --guided"
    version: "0.4.1"

# Optional configuration
severity:
  no_owner: critical
  no_scope: critical
  no_escalation: critical
  no_killswitch: critical
  no_instruction_file: critical
  no_loop_detection: warning
  no_root_cause_rule: warning
  no_api_research_rule: info
  no_attempt_counter: warning
  no_action_log: warning
  no_skill_md: warning

runtime:
  loop_threshold: 2
  progress_check_interval: 10   # every N tool calls
  token_burn_threshold: 5000
  progress_scoring: false        # requires ANTHROPIC_API_KEY if true

override:
  allowed: true
  require_reason: true
  log_overrides: true
